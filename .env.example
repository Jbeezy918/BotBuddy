# RoboBuddy - Configuration
# Uses LOCAL MODELS by default - 100% FREE!

# Your Buddy's Name (customize this!)
COMPANION_NAME=Sage

# Model Selection (change to match your Ollama models)
MODEL_CONVERSATION=gemma3:12b
MODEL_FAST=llama3.2:latest
MODEL_SMART=qwen3:14b

# Ollama URL (default works for local)
OLLAMA_URL=http://localhost:11434

# Optional - Anthropic API (fallback only)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional - Voice
# ELEVENLABS_API_KEY=
# ASSEMBLYAI_API_KEY=

# Optional - SMS Notifications
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Check-in times (24h format)
MORNING_CHECKIN_HOUR=8
EVENING_CHECKIN_HOUR=20
